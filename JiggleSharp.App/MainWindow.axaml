<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="640"
        x:Class="JiggleSharp.App.MainWindow"
        xmlns:u="https://irihi.tech/ursa"
        Title="JiggleSharp.App"
        WindowState="Normal"
        MaxWidth="640"
        MaxHeight="480">
    <Panel>
        <TextBlock Name="IdleTimeTextBlock" Text="Idle Time"/>
        <Button Name="btnSaveConfig" Click="BtnSaveConfig_OnClick"/>
    </Panel>
</Window>
